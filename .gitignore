.DS_Store
node_modules

# LibreOffice-Sperrdateien (temporär, entstehen beim Öffnen von Dokumenten)
.~lock.*#

# Interne Claude-Code-Arbeitsdateien (maschinenspezifisch)
.claude/scheduled_tasks.lock
.claude/settings.local.json

# Persoenliche Arbeitsunterlagen (gehoeren nicht in den Programmcode)
/Beispiele*/
/Unterlagen/
/build
/.svelte-kit
/package
.env
.env.*
!.env.example
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Geheimnisse / Schluessel – NIEMALS versionieren (Schutz, falls so eine
# Datei mal versehentlich im Projektordner landet – besonders wichtig,
# weil der Code jetzt auch auf GitHub liegt):
*.key
*.pem
*.crt
*.cer
*.pfx
*.p12
*.a3kpaket
# Einladungs-Dateien (enthalten einen Einmal-Token) – nicht versionieren:
*.a3keinladung
# Interne Strategie-/Monetarisierungs-Unterlagen (gehoeren NICHT ins
# oeffentliche Repo; liegen nur lokal):
docs-intern/
# Build-/Release-Artefakte (werden erzeugt, gehoeren nicht ins Repo):
*-setup.exe
*-setup.exe.sig
*-setup.exe.sha256
*.dmg
*.app.tar.gz
*.app.tar.gz.sig
