{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Antrag 3000 – Admin",
  "version": "0.2.0",
  "identifier": "com.antrag3000.admin",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Antrag 3000 – Admin",
        "width": 920,
        "height": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../../src-tauri/icons/32x32.png",
      "../../src-tauri/icons/128x128.png",
      "../../src-tauri/icons/128x128@2x.png",
      "../../src-tauri/icons/icon.icns",
      "../../src-tauri/icons/icon.ico"
    ]
  }
}
