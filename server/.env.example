# Kopiere diese Datei zu ".env" und trage deine Werte ein.
# (Die echte .env wird NICHT versioniert – siehe .gitignore.)

# === Variante A: Cloudflare Tunnel + Access (empfohlen) ===
# docker compose -f docker-compose.cloudflare.yml up -d --build
# Tunnel-Token aus dem Cloudflare-Zero-Trust-Dashboard ("Tunnel"):
TUNNEL_TOKEN=hier-dein-cloudflare-tunnel-token

# === Variante B: Direkt über DDNS + Caddy (Port 443) ===
# docker compose up -d --build
# Deine über die Synology erreichbare Adresse (DDNS):
DOMAIN=deinname.synology.me
# E-Mail für Let's Encrypt (Zertifikats-Hinweise):
ACME_EMAIL=du@example.com
