{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Antrag 3000",
  "version": "0.4.8",
  "identifier": "com.antrag3000.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Antrag 3000",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "../docs/Benutzerhandbuch Antrag 3000.pdf": "Benutzerhandbuch Antrag 3000.pdf"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "./installer-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://sync.antrag3000.de/updates/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUzOEU0REZFNDVEN0RGRTAKUldUZzM5ZEYvazJPVTJLNzhxN0RVekpLRk4yaS9ScDJ5d0s1UU1BSEdjd1grQThzNHpGUVh6SXEK"
    }
  }
}
